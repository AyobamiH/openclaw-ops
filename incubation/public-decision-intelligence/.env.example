NODE_ENV=development
HOST=127.0.0.1
PORT=4310
LOG_LEVEL=info

LEDGER_DRIVER=filesystem
FILESYSTEM_LEDGER_PATH=./var/data/ledger.json
DATABASE_URL=postgres://pdi_app:change_me@127.0.0.1:5432/public_decision_intelligence
PGVECTOR_ENABLED=true
PG_BOSS_SCHEMA=job_queue

OBJECT_STORAGE_DRIVER=filesystem
OBJECT_STORAGE_BUCKET=public-decision-intelligence
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_REGION=eu-west-2
OBJECT_STORAGE_ACCESS_KEY=change_me
OBJECT_STORAGE_SECRET_KEY=change_me
OBJECT_STORAGE_BASE_DIR=./var/object-storage

INGESTION_TMP_DIR=./var/tmp
MAX_SOURCE_FILE_MB=250
OCR_FALLBACK_ENABLED=true

REVIEW_REQUIRED_FOR_PUBLISH=true
PUBLIC_API_ENABLED=false
